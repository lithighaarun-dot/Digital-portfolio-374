<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Dark Light Mode Toggle</title>

<style>

/* Default Light Mode */

body{
font-family: Arial, sans-serif;
background-color: #ffffff;
color: #333;
text-align: center;
padding-top: 100px;
transition: background-color 0.4s, color 0.4s;
}

/* Dark Mode Style */

.dark-mode{
background-color: #121212;
color: #ffffff;
}

/* Container */

.container{
width: 350px;
margin: auto;
padding: 30px;
border-radius: 10px;
box-shadow: 0px 4px 15px rgba(0,0,0,0.2);
}

/* Button Style */

button{
padding: 12px 25px;
font-size: 16px;
border: none;
border-radius: 25px;
background-color: #007BFF;
color: white;
cursor: pointer;
transition: 0.3s;
}

button:hover{
background-color: #0056b3;
}

/* Dark Mode Container */

.dark-mode .container{
background-color: #1e1e1e;
}

</style>

</head>

<body>

<div class="container">

<h1>Dark / Light Mode</h1>

<p>Click the button to switch between Light Mode and Dark Mode.</p>

<button onclick="toggleMode()">Toggle Mode</button>

</div>

<script>

/* Toggle Function */

function toggleMode(){
document.body.classList.toggle("dark-mode");
}

</script>

</body>
</html>
