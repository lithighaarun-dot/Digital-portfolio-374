<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>REST API Integration</title>

<style>
body {
    font-family: Arial, sans-serif;
    background: #f4f4f4;
    text-align: center;
}

h1 {
    margin-top: 20px;
}

button {
    padding: 10px 20px;
    margin: 20px;
    background: #007bff;
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
}

button:hover {
    background: #0056b3;
}

#loader {
    font-size: 18px;
    color: #555;
}

.hidden {
    display: none;
}

#container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
}

.card {
    background: white;
    width: 250px;
    margin: 10px;
    padding: 15px;
    border-radius: 10px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.2);
    text-align: left;
}
</style>

</head>
<body>

<h1>REST API User Data</h1>

<button onclick="loadData()">Load Users</button>

<p id="loader" class="hidden">Loading...</p>

<div id="container"></div>

<script>
function loadData() {
    const loader = document.getElementById("loader");
    const container = document.getElementById("container");

    loader.classList.remove("hidden");
    container.innerHTML = "";

    fetch("https://jsonplaceholder.typicode.com/users")
        .then(response => response.json())
        .then(data => {
            loader.classList.add("hidden");

            data.forEach(user => {
                const card = document.createElement("div");
                card.className = "card";

                card.innerHTML = `
                    <h3>${user.name}</h3>
                    <p><strong>Email:</strong> ${user.email}</p>
                    <p><strong>Phone:</strong> ${user.phone}</p>
                    <p><strong>City:</strong> ${user.address.city}</p>
                    <p><strong>Company:</strong> ${user.company.name}</p>
                `;

                container.appendChild(card);
            });
        })
        .catch(error => {
            loader.classList.add("hidden");
            container.innerHTML = "<p>Error loading data</p>";
            console.error(error);
        });
}
</script>

</body>
</html>
