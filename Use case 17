<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Advanced Dashboard</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial;
}

body{
display:flex;
background:#eef2f7;
}

/* Sidebar */
.sidebar{
width:220px;
height:100vh;
background:#1e293b;
color:white;
padding:20px;
}

.sidebar h2{
text-align:center;
margin-bottom:30px;
}

.sidebar ul{
list-style:none;
}

.sidebar ul li{
padding:12px;
margin:10px 0;
cursor:pointer;
border-radius:5px;
}

.sidebar ul li:hover{
background:#334155;
}

/* Main */
.main{
flex:1;
padding:20px;
}

/* Topbar */
.topbar{
background:white;
padding:15px;
border-radius:10px;
box-shadow:0 2px 6px rgba(0,0,0,0.1);
margin-bottom:20px;
}

/* Cards */
.cards{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:15px;
margin-bottom:20px;
}

.card{
background:white;
padding:20px;
border-radius:10px;
text-align:center;
box-shadow:0 2px 6px rgba(0,0,0,0.1);
}

.card h3{
margin-bottom:10px;
color:#555;
}

.card p{
font-size:20px;
color:#2563eb;
}

/* Charts */
.charts{
display:grid;
grid-template-columns:1fr 1fr;
gap:20px;
}

.chart-box{
background:white;
padding:20px;
border-radius:10px;
box-shadow:0 2px 6px rgba(0,0,0,0.1);
}

/* Responsive */
@media(max-width:900px){
.cards{
grid-template-columns:1fr 1fr;
}
.charts{
grid-template-columns:1fr;
}
}

</style>
</head>

<body>

<div class="sidebar">
<h2>Dashboard</h2>
<ul>
<li>Home</li>
<li>Analytics</li>
<li>Reports</li>
<li>Settings</li>
</ul>
</div>

<div class="main">

<div class="topbar">
<h2>Welcome Back 👋</h2>
</div>

<div class="cards">
<div class="card">
<h3>Total Users</h3>
<p>1,250</p>
</div>

<div class="card">
<h3>Revenue</h3>
<p>$9,500</p>
</div>

<div class="card">
<h3>Orders</h3>
<p>320</p>
</div>

<div class="card">
<h3>Growth</h3>
<p>15%</p>
</div>
</div>

<div class="charts">

<div class="chart-box">
<h3>Sales Overview</h3>
<canvas id="barChart"></canvas>
</div>

<div class="chart-box">
<h3>Traffic Trend</h3>
<canvas id="lineChart"></canvas>
</div>

<div class="chart-box">
<h3>Market Share</h3>
<canvas id="pieChart"></canvas>
</div>

<div class="chart-box">
<h3>Weekly Data</h3>
<canvas id="doughnutChart"></canvas>
</div>

</div>

</div>

<script>

// Bar Chart
new Chart(document.getElementById("barChart"), {
type: "bar",
data: {
labels: ["Jan", "Feb", "Mar", "Apr", "May"],
datasets: [{
label: "Sales",
data: [10, 20, 15, 25, 30],
backgroundColor: "#3b82f6"
}]
}
});

// Line Chart
new Chart(document.getElementById("lineChart"), {
type: "line",
data: {
labels: ["Mon", "Tue", "Wed", "Thu", "Fri"],
datasets: [{
label: "Visitors",
data: [100, 200, 150, 300, 250],
borderColor: "#10b981",
fill: false
}]
}
});

// Pie Chart
new Chart(document.getElementById("pieChart"), {
type: "pie",
data: {
labels: ["A", "B", "C"],
datasets: [{
data: [40, 30, 30],
backgroundColor: ["#ef4444", "#3b82f6", "#facc15"]
}]
}
});

// Doughnut Chart
new Chart(document.getElementById("doughnutChart"), {
type: "doughnut",
data: {
labels: ["Red", "Blue", "Yellow"],
datasets: [{
data: [25, 50, 25],
backgroundColor: ["#ef4444", "#3b82f6", "#facc15"]
}]
}
});

</script>

</body>
</html>
